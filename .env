# Debian: instalar Docker (https://docs.docker.com/engine/install/debian/)
#   sudo apt update && sudo apt install -y docker.io docker-compose-plugin
# Copiar y editar: cp .env.example .env
#
# Red externa del reverse proxy (una sola vez en el servidor):
#   docker network create proxy-network
#
# SA_PASSWORD: requisitos SQL Server (mayúscula, minúscula, número, símbolo, 8+ caracteres).
SA_PASSWORD=Cambiar1!Segura
#
# JWT_SIGNING_KEY: mínimo 32 caracteres (HS256).
JWT_SIGNING_KEY=CAMBIAR-CLAVE-JWT-256-bits-MIN-32-CHARS!!
JWT_ISSUER=POS
JWT_AUDIENCE=pos-clients
#
# El acceso HTTP lo publica el reverse proxy (proxy-network).
# Apuntá el proxy al servicio facturacion-web:80 (SPA + /api/).
#
# Modo solo imágenes (docker-compose.pull.yml en Debian sin build):
# POS_API_IMAGE=ghcr.io/tu-org/tu-repo-pos-api:latest
# POS_WEB_IMAGE=ghcr.io/tu-org/tu-repo-pos-web:latest
# Tras cambios en Dockerfiles/nginx, volver a construir/publicar imágenes.
