# Debian: instalar Docker (https://docs.docker.com/engine/install/debian/)
#   sudo apt update && sudo apt install -y docker.io docker-compose-plugin
# Copiar y editar: cp .env.example .env
#
# SA_PASSWORD: requisitos SQL Server (mayúscula, minúscula, número, símbolo, 8+ caracteres).
SA_PASSWORD=Cambiar1!Segura
#
# JWT_SIGNING_KEY: mínimo 32 caracteres (HS256).
JWT_SIGNING_KEY=CAMBIAR-CLAVE-JWT-256-bits-MIN-32-CHARS!!
JWT_ISSUER=POS
JWT_AUDIENCE=pos-clients
#
# Puerto en el host donde el contenedor nginx sirve el SPA (API por /api/ mismo origen).
# Si nginx del sistema hace proxy, usa 127.0.0.1 para no exponer el puerto a la red.
HTTP_LISTEN_ADDR=0.0.0.0
HTTP_PORT=8080
#
# HTTPS con Caddy en Docker (Let's Encrypt). Requiere DNS A hacia este servidor.
#   docker compose -f docker-compose.yml -f docker-compose.https.yml up -d
# Mismo patrón con: docker-compose.pull.yml + docker-compose.https.yml
# CADDY_DOMAIN=pos.tudominio.com
#
# TLS con nginx en el host (certbot): ver deploy/debian/nginx-host-proxy.example.conf
#
# Modo solo imágenes (docker-compose.pull.yml en Debian sin build):
# POS_API_IMAGE=ghcr.io/tu-org/tu-repo-pos-api:latest
# POS_WEB_IMAGE=ghcr.io/tu-org/tu-repo-pos-web:latest
# Tras cambios en Dockerfiles, volver a construir/publicar imágenes (healthcheck usa curl en la API).
